	(text "DMA ch2/3 + raw ~WR/IO-M are NOT wired to the MCU (48-GPIO budget, S5.2): DACK2/3 parked high, DRQ2/3 low. First candidates for a second '165/'595 if sidecar DMA is ever needed."
		(at 86.36 15.24 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "76de77a4-e90d-5688-b801-aaa23d20c795")
	)
	(text "U6 strobes DIR = HLDA (bus role, §5.2);  DATADIR = data read/write dir;"
		(at 200.66 116.84 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
