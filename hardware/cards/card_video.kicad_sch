	(text "SOFT CARD: ISA bus + power ONLY. Self-decodes 0xA0000-0xBFFFF and 3B4/3B5/3B8/3BA/3BF + 3D4/3D5/3D8/3D9/3DA from snooped A17-A19/A0-A9. No Y5, no link, no host RAM (design S8)."
		(at 38.1 20.32 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "fca3a960-1280-437b-ad43-b12e1940412f")
	)
	(text "Standalone Video PCB: ISA bus chains J_IN -> J_OUT; card logic taps the bus by name. Daisy-chain cards header-to-header (isa_conn, S4.3)."
